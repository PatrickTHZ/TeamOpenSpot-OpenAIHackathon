{
  "name": "@cloudflare/vitest-pool-workers",
  "version": "0.15.1",
  "description": "Workers Vitest integration for writing Vitest unit and integration tests that run inside the Workers runtime",
  "keywords": [
    "cloudflare",
    "environment",
    "integration",
    "jest",
    "miniflare",
    "pool",
    "test",
    "unit",
    "vitest",
    "worker",
    "workers"
  ],
  "homepage": "https://github.com/cloudflare/workers-sdk/tree/main/packages/vitest-pool-workers#readme",
  "bugs": {
    "url": "https://github.com/cloudflare/workers-sdk/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/workers-sdk.git",
    "directory": "packages/vitest-pool-workers"
  },
  "files": [
    "dist",
    "types/cloudflare-test.d.ts"
  ],
  "type": "module",
  "main": "dist/pool/index.mjs",
  "types": "dist/pool/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/pool/index.d.mts",
      "import": "./dist/pool/index.mjs"
    },
    "./types": {
      "types": "./types/cloudflare-test.d.ts"
    },
    "./codemods/vitest-v3-to-v4": {
      "import": "./dist/codemods/vitest-v3-to-v4.mjs"
    }
  },
  "dependencies": {
    "cjs-module-lexer": "^1.2.3",
    "esbuild": "0.27.3",
    "zod": "^3.25.76",
    "miniflare": "4.20260426.0",
    "wrangler": "4.86.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^22.10.1",
    "@types/semver": "^7.5.1",
    "@vitest/runner": "4.1.0",
    "@vitest/snapshot": "4.1.0",
    "birpc": "0.2.14",
    "capnp-es": "^0.0.14",
    "devalue": "^5.6.3",
    "get-port": "^7.1.0",
    "jscodeshift": "^17.3.0",
    "semver": "^7.7.1",
    "tree-kill": "^1.2.2",
    "ts-dedent": "^2.2.0",
    "tsdown": "0.16.3",
    "typescript": "~5.8.3",
    "undici": "7.24.8",
    "vitest": "4.1.0",
    "@cloudflare/workers-tsconfig": "0.0.0",
    "@cloudflare/workers-utils": "0.18.0",
    "@cloudflare/workflows-shared": "0.9.1",
    "@cloudflare/mock-npm-registry": "0.0.0"
  },
  "peerDependencies": {
    "@vitest/runner": "^4.1.0",
    "@vitest/snapshot": "^4.1.0",
    "vitest": "^4.1.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "workers-sdk": {
    "prerelease": true
  },
  "scripts": {
    "build": "tsdown",
    "capnp:rtti": "capnp-es scripts/rtti/rtti.capnp -ojs",
    "check:type": "tsc && tsc -p src/worker/tsconfig.json && tsc -p types/tsconfig.json",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:ci": "vitest run"
  }
}