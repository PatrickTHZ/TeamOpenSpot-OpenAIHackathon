{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["src/index.ts", "src/scoring.ts", "src/contract.ts", "src/types.ts", "test", "../shared"],
  "exclude": ["test/selfhost-ocr.test.ts", "src/selfhost.ts", "src/selfhost-ocr.ts", "src/selfhost-storage.ts"]
}
